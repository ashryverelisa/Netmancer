<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:NetmancerOld.ViewModels"
             xmlns:models="clr-namespace:NetmancerOld.Models"
             xmlns:converters="clr-namespace:NetmancerOld.Converters"
             xmlns:views="clr-namespace:NetmancerOld.Views"
             x:Class="NetmancerOld.Views.BrowseFoldersView"
             x:DataType="viewmodels:BrowseFoldersViewModel"
             Title="{Binding DeviceName}"
             BackgroundColor="{StaticResource DarkBackground}">

    <ContentPage.Resources>
        <converters:InvertBoolConverter x:Key="InvertBoolConverter" />
        <converters:IsNullConverter x:Key="IsNullConverter" />
        <converters:IsNotNullConverter x:Key="IsNotNullConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">

        <!-- Loading indicator -->
        <ActivityIndicator Grid.Row="0"
                           IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           Color="{StaticResource Accent}"
                           VerticalOptions="Center"
                           HorizontalOptions="Center" />

        <!-- Error message -->
        <VerticalStackLayout Grid.Row="0"
                             IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Spacing="12"
                             Padding="24">
            <Label Text="⚠️"
                   FontSize="48"
                   HorizontalTextAlignment="Center" />
            <Label Text="{Binding ErrorMessage}"
                   FontSize="14"
                   TextColor="{StaticResource TextSecondary}"
                   HorizontalTextAlignment="Center" />
            <Button Text="Retry"
                    Command="{Binding LoadFoldersCommand}"
                    BackgroundColor="{StaticResource Accent}"
                    TextColor="{StaticResource White}"
                    CornerRadius="8"
                    HorizontalOptions="Center"
                    Padding="24,8" />
        </VerticalStackLayout>

        <!-- Content List -->
        <CollectionView Grid.Row="0"
                        ItemsSource="{Binding Items}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ContentItem">
                    <Grid Padding="16,6" ColumnDefinitions="48,*,Auto" ColumnSpacing="14">

                        <!-- Icon / Album Art Area -->
                        <Border Grid.Column="0"
                                StrokeThickness="0"
                                HeightRequest="44"
                                WidthRequest="44"
                                BackgroundColor="{StaticResource DarkCardBackground}"
                                HorizontalOptions="Center"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Grid>
                                <!-- Emoji icon (folders + items without art) -->
                                <Label Text="{Binding Icon}"
                                       FontSize="20"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center"
                                       IsVisible="{Binding AlbumArtUri, Converter={StaticResource IsNullConverter}}" />
                                <!-- Album art thumbnail (audio items with art) -->
                                <Image Source="{Binding AlbumArtUri}"
                                       Aspect="AspectFill"
                                       HeightRequest="44"
                                       WidthRequest="44"
                                       IsVisible="{Binding HasAlbumArt}" />
                            </Grid>
                        </Border>

                        <!-- Title & Subtitle -->
                        <VerticalStackLayout Grid.Column="1"
                                             VerticalOptions="Center"
                                             Spacing="2">
                            <Label Text="{Binding Title}"
                                   FontSize="15"
                                   TextColor="{StaticResource TextPrimary}"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="1" />
                            <Label Text="{Binding Subtitle}"
                                   FontSize="12"
                                   TextColor="{StaticResource TextSecondary}"
                                   IsVisible="{Binding IsContainer, Converter={StaticResource InvertBoolConverter}}" />
                        </VerticalStackLayout>

                        <!-- Chevron for containers -->
                        <Label Grid.Column="2"
                               Text="›"
                               FontSize="22"
                               TextColor="{StaticResource TextMuted}"
                               VerticalTextAlignment="Center"
                               IsVisible="{Binding IsContainer}"
                               Margin="0,0,4,0" />

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:BrowseFoldersViewModel}}, Path=ItemTappedCommand}"
                                CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="8"
                                     Margin="0,60,0,0">
                    <Label Text="📂"
                           FontSize="48"
                           HorizontalTextAlignment="Center" />
                    <Label Text="No items found."
                           HorizontalTextAlignment="Center"
                           FontSize="16"
                           TextColor="{StaticResource TextSecondary}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

        <!-- Mini Player -->
        <views:MiniPlayerView Grid.Row="1" x:Name="MiniPlayer" />

    </Grid>
</ContentPage>
