<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Netmancer.ViewModels"
             xmlns:views="using:Netmancer.Views"
             mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="700"
             x:Class="Netmancer.Views.MainView"
             x:DataType="vm:MainViewModel"
             Background="{DynamicResource DarkBackgroundBrush}">

    <DockPanel>
        <!-- Mini Player — always visible at the bottom when a track is loaded -->
        <views:MiniPlayerView DockPanel.Dock="Bottom"
                              DataContext="{Binding MiniPlayer}" />

        <!-- Current page content — resolved by ViewLocator from the ViewModel type -->
        <ContentControl Content="{Binding CurrentPage}" />
    </DockPanel>
</UserControl>
