<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Netmancer.ViewModels"
             xmlns:views="using:Netmancer.Views"
             mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="700"
             x:Class="Netmancer.Views.MainView"
             x:DataType="vm:MainViewModel"
             Background="{DynamicResource DarkBackgroundBrush}">
    <DockPanel>
        <Panel DockPanel.Dock="Bottom"
               IsVisible="{Binding ShowMiniPlayer}">
            <views:MiniPlayerView DataContext="{Binding MiniPlayer}" />
        </Panel>
      <ContentControl Content="{Binding CurrentPage}" />
    </DockPanel>
</UserControl>
