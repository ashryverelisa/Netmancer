<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Netmancer.ViewModels"
             xmlns:models="using:Netmancer.Models"
             mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="700"
             x:Class="Netmancer.Views.MediaServersView"
             x:DataType="vm:MediaServersViewModel">

    <DockPanel>
        <!-- Custom Header -->
        <DockPanel DockPanel.Dock="Top" Margin="20,16,12,8">
            <Button DockPanel.Dock="Right"
                    Content="⟳"
                    FontSize="22"
                    Foreground="{DynamicResource AccentBrush}"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{Binding SearchCommand}"
                    Width="48" Height="48"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center" />
            <StackPanel VerticalAlignment="Center" Spacing="2">
                <TextBlock Text="Netmancer"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock Text="Select a media server"
                           FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
            </StackPanel>
        </DockPanel>

        <!-- Section header -->
        <TextBlock DockPanel.Dock="Top"
                   Text="AVAILABLE DEVICES"
                   FontSize="11"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextMutedBrush}"
                   Margin="20,12,20,8"
                   LetterSpacing="1.5" />

        <!-- Content area -->
        <Panel>
            <!-- Empty state -->
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16"
                        IsVisible="{Binding !Devices.Count}">

                <StackPanel Spacing="6" HorizontalAlignment="Center">
                    <TextBlock Text="Looking for servers"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextAlignment="Center" />
                    <TextBlock Text="Make sure a UPnP/DLNA media server&#10;is running on your network"
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextAlignment="Center"
                               LineHeight="20" />
                </StackPanel>

                <ProgressBar IsIndeterminate="True"
                             IsVisible="{Binding IsSearching}"
                             HorizontalAlignment="Center"
                             Width="120"
                             Foreground="{DynamicResource AccentBrush}" />
            </StackPanel>

            <!-- Device list -->
            <ListBox ItemsSource="{Binding Devices}"
                     SelectedItem="{Binding SelectedDevice}"
                     Background="Transparent"
                     IsVisible="{Binding Devices.Count}">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#10FFFFFF" />
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:MediaDevice">
                        <Border Background="{DynamicResource DarkCardBackgroundBrush}"
                                CornerRadius="14"
                                Margin="16,5"
                                Padding="14,16"
                                BoxShadow="0 2 6 0 #40000000">
                            <Grid ColumnDefinitions="60,*,Auto" ColumnSpacing="14">
                                <!-- Icon -->
                                <Border Grid.Column="0"
                                        Background="#1A00BFA5"
                                        Height="44" Width="44"
                                        CornerRadius="12"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="≡"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource AccentBrush}" />
                                </Border>

                                <!-- Name + Address -->
                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Spacing="3">
                                    <TextBlock Text="{Binding FriendlyName}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1" />
                                    <TextBlock Text="{Binding Address}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                </StackPanel>

                                <!-- Arrow -->
                                <TextBlock Grid.Column="2"
                                           Text="→"
                                           FontSize="18"
                                           Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Opacity="0.7"
                                           Margin="0,0,4,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Panel>
    </DockPanel>
</UserControl>

