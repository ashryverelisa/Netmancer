<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Netmancer.ViewModels"
             xmlns:models="clr-namespace:Netmancer.Models"
             xmlns:views="clr-namespace:Netmancer.Views"
             x:Class="Netmancer.Views.MediaServersView"
             x:DataType="viewmodels:MediaServersViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource DarkBackground}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Custom Header -->
        <Grid Grid.Row="0"
              Padding="20,16,12,8"
              ColumnDefinitions="*,Auto"
              BackgroundColor="{StaticResource DarkBackground}">
            <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                <Label Text="Netmancer"
                       FontSize="26"
                       FontAttributes="Bold"
                       FontFamily="OpenSansSemibold"
                       TextColor="{StaticResource TextPrimary}" />
                <Label Text="Select a media server"
                       FontSize="13"
                       TextColor="{StaticResource TextSecondary}" />
            </VerticalStackLayout>
            <Button Grid.Column="1"
                    Text="⟳"
                    FontSize="22"
                    TextColor="{StaticResource Accent}"
                    BackgroundColor="Transparent"
                    Command="{Binding SearchCommand}"
                    WidthRequest="48"
                    HeightRequest="48"
                    Padding="0"
                    VerticalOptions="Center" />
        </Grid>

        <!-- Pull-to-refresh wrapper -->
        <RefreshView Grid.Row="1"
                     Command="{Binding SearchCommand}"
                     RefreshColor="{StaticResource Accent}">

            <CollectionView ItemsSource="{Binding Devices}"
                            SelectionMode="None">

                <!-- Section header -->
                <CollectionView.Header>
                    <Label Text="AVAILABLE DEVICES"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextMuted}"
                           Padding="20,12,20,8"
                           CharacterSpacing="1.5" />
                </CollectionView.Header>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:MediaDevice">

                        <!-- Device Row -->
                        <Grid Padding="16,5">
                            <Border BackgroundColor="{StaticResource DarkCardBackground}"
                                    Padding="0"
                                    StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.25" />
                                </Border.Shadow>

                                <Grid ColumnDefinitions="60,*,Auto"
                                      Padding="14,16"
                                      ColumnSpacing="14">

                                    <!-- Icon -->
                                    <Border Grid.Column="0"
                                            BackgroundColor="#1A00BFA5"
                                            HeightRequest="44"
                                            WidthRequest="44"
                                            StrokeThickness="0"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12" />
                                        </Border.StrokeShape>
                                        <Label Text="≡"
                                               FontSize="22"
                                               FontAttributes="Bold"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center"
                                               TextColor="{StaticResource Accent}" />
                                    </Border>

                                    <!-- Name + Address -->
                                    <VerticalStackLayout Grid.Column="1"
                                                         VerticalOptions="Center"
                                                         Spacing="3">
                                        <Label Text="{Binding FriendlyName}"
                                               FontSize="16"
                                               FontFamily="OpenSansSemibold"
                                               TextColor="{StaticResource TextPrimary}"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="1" />
                                        <Label Text="{Binding Address}"
                                               FontSize="12"
                                               TextColor="{StaticResource TextSecondary}" />
                                    </VerticalStackLayout>

                                    <!-- Arrow -->
                                    <Label Grid.Column="2"
                                           Text="→"
                                           FontSize="18"
                                           TextColor="{StaticResource Accent}"
                                           VerticalTextAlignment="Center"
                                           HorizontalTextAlignment="Center"
                                           Opacity="0.7"
                                           Margin="0,0,4,0" />

                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MediaServersViewModel}}, Path=DeviceTappedCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <Grid VerticalOptions="Center"
                          HorizontalOptions="Center"
                          Margin="0,80,0,0">
                        <VerticalStackLayout Spacing="16"
                                             HorizontalOptions="Center">
                            <!-- Stylized icon -->
                            <Border BackgroundColor="#1A00BFA5"
                                    HeightRequest="80"
                                    WidthRequest="80"
                                    StrokeThickness="0"
                                    HorizontalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20" />
                                </Border.StrokeShape>
                                <Label Text="📡"
                                       FontSize="36"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Border>

                            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                <Label Text="Looking for servers"
                                       FontSize="18"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource TextPrimary}"
                                       HorizontalTextAlignment="Center" />
                                <Label Text="Make sure a UPnP/DLNA media server&#10;is running on your network"
                                       FontSize="13"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalTextAlignment="Center"
                                       LineHeight="1.4" />
                            </VerticalStackLayout>

                            <ActivityIndicator IsRunning="{Binding IsSearching}"
                                               IsVisible="{Binding IsSearching}"
                                               HorizontalOptions="Center"
                                               HeightRequest="24"
                                               WidthRequest="24"
                                               Color="{StaticResource Accent}" />
                        </VerticalStackLayout>
                    </Grid>
                </CollectionView.EmptyView>

                <!-- Bottom padding -->
                <CollectionView.Footer>
                    <BoxView HeightRequest="8" Color="Transparent" />
                </CollectionView.Footer>

            </CollectionView>
        </RefreshView>

        <!-- Mini Player -->
        <views:MiniPlayerView Grid.Row="2" x:Name="MiniPlayer" />

    </Grid>
</ContentPage>