<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Netmancer.ViewModels"
             xmlns:models="clr-namespace:Netmancer.Models"
             x:Class="Netmancer.Views.MediaServersView">

    <CollectionView ItemsSource="{Binding Devices}"
                    x:DataType="viewmodels:MediaServersViewModel"
                    SelectionMode="None">
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:MediaDevice">
                <Grid Padding="16,8">
                    <Label Text="{Binding FriendlyName}"
                           FontSize="16"
                           VerticalTextAlignment="Center" />
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer
                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MediaServersViewModel}}, Path=DeviceTappedCommand}"
                            CommandParameter="{Binding .}" />
                    </Grid.GestureRecognizers>
                </Grid>
            </DataTemplate>
        </CollectionView.ItemTemplate>
        <CollectionView.EmptyView>
            <Label Text="Searching for devices…"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center"
                   FontSize="16"
                   TextColor="Gray"
                   Margin="0,40,0,0" />
        </CollectionView.EmptyView>
    </CollectionView>
</ContentPage>