<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Netmancer.ViewModels"
             xmlns:converters="clr-namespace:Netmancer.Converters"
             xmlns:behaviors="clr-namespace:Netmancer.Behaviors"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Netmancer.Views.NowPlayingView"
             x:DataType="viewmodels:NowPlayingViewModel"
             Title="Now Playing"
             BackgroundColor="{StaticResource DarkBackground}"
             Shell.PresentationMode="ModalAnimated">

    <ContentPage.Resources>
        <converters:IsNullConverter x:Key="IsNullConverter" />
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="✕" Command="{Binding GoBackCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto" Padding="24,16">

        <!-- Hidden audio player -->
        <toolkit:MediaElement x:Name="Player"
                              IsVisible="False"
                              HeightRequest="0"
                              WidthRequest="0"
                              ShouldAutoPlay="{Binding AutoPlay}"
                              ShouldShowPlaybackControls="False"
                              Source="{Binding PlayerSource}"
                              Volume="{Binding Volume}">
            <toolkit:MediaElement.Behaviors>
                <behaviors:MediaElementPlaybackBehavior />
            </toolkit:MediaElement.Behaviors>
        </toolkit:MediaElement>

        <!-- Album Art -->
        <Border Grid.Row="1"
                StrokeThickness="0"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                MaximumHeightRequest="320"
                MaximumWidthRequest="320"
                BackgroundColor="{StaticResource DarkCardBackground}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="16" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,8" Radius="24" Opacity="0.5" />
            </Border.Shadow>
            <Grid HeightRequest="300" WidthRequest="300">
                <!-- Fallback: music note when no album art -->
                <Label Text="🎵"
                       FontSize="100"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"
                       TextColor="{StaticResource TextMuted}"
                       IsVisible="{Binding AlbumArtUri, Converter={StaticResource IsNullConverter}}" />
                <!-- Album art image -->
                <Image Source="{Binding AlbumArtUri}"
                       Aspect="AspectFill"
                       HeightRequest="300"
                       WidthRequest="300" />
            </Grid>
        </Border>

        <!-- Track Info -->
        <VerticalStackLayout Grid.Row="2" Spacing="4" Padding="0,24,0,0"
                             HorizontalOptions="Center">
            <Label Text="{Binding TrackTitle}"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="TailTruncation"
                   MaxLines="2" />
            <Label Text="{Binding ArtistName}"
                   FontSize="16"
                   TextColor="{StaticResource TextSecondary}"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="TailTruncation"
                   MaxLines="1" />
        </VerticalStackLayout>

        <!-- Position Slider -->
        <Grid Grid.Row="3" Padding="0,20,0,0" RowDefinitions="Auto,Auto">
            <Slider x:Name="PositionSlider"
                    Minimum="0"
                    Maximum="{Binding Position.DurationSeconds}"
                    Value="{Binding Position.PositionSeconds}"
                    MinimumTrackColor="{StaticResource Accent}"
                    MaximumTrackColor="{StaticResource DarkCardBackground}"
                    ThumbColor="{StaticResource Accent}">
                <Slider.Behaviors>
                    <toolkit:EventToCommandBehavior EventName="DragStarted"
                                                    Command="{Binding Position.DragStartedCommand}" />
                    <toolkit:EventToCommandBehavior EventName="DragCompleted"
                                                    Command="{Binding Position.DragCompletedCommand}" />
                </Slider.Behaviors>
            </Slider>
            <Grid Grid.Row="1" ColumnDefinitions="*,*">
                <Label Grid.Column="0"
                       Text="{Binding Position.PositionDisplay}"
                       FontSize="12"
                       TextColor="{StaticResource TextSecondary}"
                       HorizontalTextAlignment="Start" />
                <Label Grid.Column="1"
                       Text="{Binding Position.DurationDisplay}"
                       FontSize="12"
                       TextColor="{StaticResource TextSecondary}"
                       HorizontalTextAlignment="End" />
            </Grid>
        </Grid>

        <!-- Playback Controls -->
        <HorizontalStackLayout Grid.Row="4"
                               HorizontalOptions="Center"
                               Spacing="32"
                               Padding="0,16,0,0">
            <!-- Previous -->
            <Button Text="⏮"
                    Command="{Binding PreviousCommand}"
                    FontSize="32"
                    TextColor="{StaticResource TextPrimary}"
                    BackgroundColor="Transparent"
                    WidthRequest="64"
                    HeightRequest="64"
                    Padding="0"
                    VerticalOptions="Center" />

            <!-- Play / Pause -->
            <Border StrokeThickness="0"
                    BackgroundColor="{StaticResource Accent}"
                    HeightRequest="72"
                    WidthRequest="72"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="36" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="{StaticResource Accent}" Offset="0,4" Radius="16" Opacity="0.4" />
                </Border.Shadow>
                <Button Text="{Binding PlayPauseIcon}"
                        Command="{Binding PlayPauseCommand}"
                        FontSize="32"
                        TextColor="{StaticResource White}"
                        BackgroundColor="Transparent"
                        Padding="0"
                        VerticalOptions="Center"
                        HorizontalOptions="Center" />
            </Border>

            <!-- Next -->
            <Button Text="⏭"
                    Command="{Binding NextCommand}"
                    FontSize="32"
                    TextColor="{StaticResource TextPrimary}"
                    BackgroundColor="Transparent"
                    WidthRequest="64"
                    HeightRequest="64"
                    Padding="0"
                    VerticalOptions="Center" />
        </HorizontalStackLayout>

        <!-- Volume Control -->
        <Grid Grid.Row="5" Padding="24,20,24,0" ColumnDefinitions="Auto,*,Auto">
            <Label Text="🔈"
                   FontSize="16"
                   TextColor="{StaticResource TextSecondary}"
                   VerticalTextAlignment="Center" />
            <Slider Grid.Column="1"
                    Minimum="0"
                    Maximum="1"
                    Value="{Binding Volume}"
                    Margin="8,0"
                    MinimumTrackColor="{StaticResource Accent}"
                    MaximumTrackColor="{StaticResource DarkCardBackground}"
                    ThumbColor="{StaticResource Accent}" />
            <Label Text="🔊"
                   Grid.Column="2"
                   FontSize="16"
                   TextColor="{StaticResource TextSecondary}"
                   VerticalTextAlignment="Center" />
        </Grid>

        <!-- Bottom spacer -->
        <BoxView Grid.Row="6" HeightRequest="24" Color="Transparent" />
    </Grid>
</ContentPage>

