<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Netmancer.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Netmancer"
    xmlns:views="clr-namespace:Netmancer.Views"
    Title="Netmancer">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

    <ShellContent
        Title="Media Servers"
        Route="MediaServers"
        x:Name="MediaServersShellContent" />

</Shell>
